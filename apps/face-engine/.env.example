# 服务绑定（默认只听回环，由 Node 内网调用）
FACE_ENGINE_HOST=127.0.0.1
FACE_ENGINE_PORT=8077

# 与 Node 后端约定的内网调用密钥（必填，留空则拒绝所有 analyze 调用）
FACE_ENGINE_SHARED_SECRET=change-me-please

# 识别模型（InsightFace）
FACE_ENGINE_MODEL_NAME=buffalo_l
FACE_ENGINE_DET_SIZE=640
FACE_ENGINE_PROVIDERS=CPUExecutionProvider

# 活体（Silent-Face）
FACE_ENGINE_LIVENESS_ENABLED=true
FACE_ENGINE_LIVENESS_MODEL_DIR=./models/silent_face
FACE_ENGINE_LIVENESS_THRESHOLD=0.6

# 单次请求最多帧数
FACE_ENGINE_MAX_FRAMES=16
