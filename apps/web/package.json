    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.1",
    "@tanstack/react-query": "^5.85.3",
    "@types/papaparse": "^5.3.16",
    "antd": "^5.27.1",
    "axios": "^1.12.2",
    "dayjs": "^1.11.13",
    "lucide-react": "^0.540.0",
    "node-forge": "^1.3.1",
    "nprogress": "^0.2.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.1",
    "react-datepicker": "^8.7.0",
    "react-dom": "^19.1.1",
