    "cross-env": "^7.0.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vite": "^5.4.19",
    "vite-tsconfig-paths": "^5.1.4",
    "vite-plugin-checker": "^0.7.0"
  }
