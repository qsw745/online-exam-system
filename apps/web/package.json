{
  "name": "web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "tsc -w --noEmit -p tsconfig.json",
    "build": "rimraf node_modules/.vite-temp && vite build",
