DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=exam_system
DB_USER=root
DB_PASSWORD=root

NODE_ENV=development
PORT=8848
FRONTEND_URL=http://localhost:5173

JWT_SECRET=change-me
REFRESH_JWT_SECRET=change-me-too
ACCESS_JWT_EXPIRES_IN=15m
REFRESH_JWT_EXPIRES_IN=7d
ACCESS_JWT_CLOCK_TOLERANCE=0s

REDIS_URL=redis://127.0.0.1:6380/0
REDIS_PREFIX=online-exam:dev
SESSION_LIST_LIMIT=200

LOG_LEVEL=error
FILE_LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_RETENTION=14d

SQL_DEBUG=0
DEBUG_SQL=0
