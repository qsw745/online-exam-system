DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=exam_system
DB_USER=root
DB_PASSWORD=root

NODE_ENV=development
PORT=8848
FRONTEND_URL=http://localhost:5173

JWT_SECRET=change-me
REFRESH_JWT_SECRET=change-me-too
ACCESS_JWT_EXPIRES_IN=15m
REFRESH_JWT_EXPIRES_IN=7d
ACCESS_JWT_CLOCK_TOLERANCE=0s

REDIS_URL=redis://127.0.0.1:6380/0
REDIS_PREFIX=online-exam:dev
SESSION_LIST_LIMIT=200

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override for OAuth frontend callback origin. Defaults to the current request origin.
OAUTH_FRONTEND_URL=

LOG_LEVEL=error
FILE_LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_RETENTION=14d

SQL_DEBUG=0
DEBUG_SQL=0

# --- 人脸引擎（apps/face-engine）---
FACE_ENGINE_URL=http://127.0.0.1:8077
FACE_ENGINE_SHARED_SECRET=
FACE_ENGINE_TIMEOUT_MS=15000
FACE_MATCH_THRESHOLD=0.4
FACE_MAX_SAMPLES=3
FACE_CONSENT_VERSION=2026-06-v1
# 是否强制活体（生产=true）。开发期活体模型未就绪可临时 false 以联调
FACE_REQUIRE_LIVENESS=true
# 动作活体（转头）：开启后要求采集期间头部实际转动，防静态照片
FACE_REQUIRE_ACTION_LIVENESS=false
FACE_ACTION_YAW_MIN=18
