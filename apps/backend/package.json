{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "description": "Online Exam System Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "concurrently -k -n SVC,TYPE \"pnpm dev:server\" \"pnpm typecheck:watch\"",
    "dev:server": "tsx watch src/app.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "tsc -w --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "db": "knex --knexfile ./knexfile.ts",
    "db:make": "knex --knexfile ./knexfile.ts migrate:make",
    "db:latest": "knex --knexfile ./knexfile.ts migrate:latest",
    "db:rollback": "knex --knexfile ./knexfile.ts migrate:rollback",
    "db:status": "knex --knexfile ./knexfile.ts migrate:list",
    "db:seed": "knex --knexfile ./knexfile.ts seed:run",
    "dev:with-db": "pnpm db:latest && pnpm dev",
    "db:bootstrap": "tsx scripts/db/bootstrap.ts",
    "db:drop": "tsx scripts/db/drop.ts",
    "db:setup": "pnpm db:bootstrap && pnpm db:latest && pnpm db:seed",
    "db:rebuild": "pnpm db:drop && pnpm db:setup",
    "dev:with-db:seed": "pnpm db:setup && pnpm dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "antd": "^5.27.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.2.1",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.11.2",
    "nodemailer": "^6.9.8",
    "path": "^0.12.7",
    "pino-http": "^10.5.0",
    "source-map-support": "^0.5.21",
    "svg-captcha": "^1.4.0",
    "tsconfig-paths": "^4.2.0",
    "ua-parser-js": "^2.0.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^6.4.14",
    "@types/react-datepicker": "^7.0.0",
    "cross-env": "^7.0.3",
    "knex": "^3.1.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.4.5"
  }
}
