{
  "name": "online-exam-system",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "description": "Monorepo for Online Exam System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -r -n api,web -c yellow,cyan \"pnpm -C apps/backend dev\" \"pnpm -C apps/web dev\"",
    "dev:api": "pnpm -C apps/backend dev",
    "dev:web": "pnpm -C apps/web dev",
    "lint": "eslint .",
    "lint:i18n": "eslint \"apps/web/src/**/*.{ts,tsx}\"",
    "lint:i18n:report": "eslint \"apps/web/src/**/*.{ts,tsx}\" -f stylish | grep no-literal-string | sed -E 's/.*disallow literal string: //' || true",
    "audit:i18n:literals": "node apps/web/scripts/audit-i18n-literals.mjs --fail",
    "audit:i18n:literals:report": "node apps/web/scripts/audit-i18n-literals.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "mysql2": "3.10.0",
    "tsconfig-paths": "4.2.0"
  },
  "pnpm": {
    "overrides": {
      "diff": "4.0.4",
      "path-to-regexp": "0.1.13",
      "picomatch": "2.3.2"
    }
  }
}
